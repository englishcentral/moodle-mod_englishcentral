{{!
    @template mod_englishcentral/mobile_view_page

    Embeds the EnglishCentral activity view page in an iframe within
    the mobile app.

    Example context (json):
    {
        "wwwroot": "https://example.com",
        "cmid": "2",
        "user_id": "3",
        "secret": "abc123"
    }
}}
{{=<% %>=}}
<div style="height: 100%; width: 100%; background: white;">
    <iframe
            id="englishcentral-mobileapp-iframe"
            style="width: 100%; height: 100%; border: 0;"
            src="<% wwwroot %>/mod/englishcentral/view.php?id=<% cmid %>&user_id=<% user_id %>&secret=<% secret %>&embed=2"
            allow="microphone; camera"
            allowfullscreen="allowfullscreen">
    </iframe>
</div>
