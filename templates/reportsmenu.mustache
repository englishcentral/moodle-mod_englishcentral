{{!
    @template mod_englishcentral/reportsmenu

    Menu of available EnglishCentral reports.

    Example context (json):
    {
        "reports": [
            {
                "button": "<a href=\"https://example.com/mod/englishcentral/report.php\">View</a>",
                "text": "Course attempts report"
            }
        ]
    }
}}
<div class="clearfix">{{#str}}reportsmenutoptext, mod_englishcentral{{/str}}</div>
<div class="englishcentral_reportsmenu_box">
    {{#reports}}
        <div class="englishcentral_reportsmenu_item">
            <div class="englishcentral_reportsmenu_itembutton">
                {{{button}}}
            </div>
            <div class="englishcentral_reportsmenu_itemtext">
                {{text}}
            </div>
        </div>
    {{/reports}}
</div>
